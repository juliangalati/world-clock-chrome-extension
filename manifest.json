{
  "manifest_version": 3,
  "name": "World Clock",
  "version": "1.0",
  "description": "Your local time and a second timezone of your choosing, at a glance",
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "World Clock"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["alarms", "storage"]
}
